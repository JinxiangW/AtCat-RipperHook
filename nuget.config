<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-level NuGet config. Higher precedence than the in-submodule
  AssetRipper/nuget.config (which declares SamboyDev only and would
  shadow nuget.org if passed explicitly to dotnet build, breaking
  restore of public packages like K4os.Compression.LZ4, SharpCompress,
  Microsoft.NET.ILLink.Tasks, etc.). Both feeds are declared here so
  every project resolves cleanly without per-job config gymnastics.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="SamboyDev" value="https://nuget.samboy.dev/v3/index.json" />
  </packageSources>
</configuration>
